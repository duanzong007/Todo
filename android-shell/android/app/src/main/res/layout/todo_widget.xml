<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/todo_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/todo_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/todo_widget_title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/todo_widget_title"
            android:textColor="@color/todo_widget_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/todo_widget_status"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical|right"
            android:maxLines="1"
            android:textColor="@color/todo_widget_muted"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/todo_widget_refresh"
            android:layout_width="32dp"
            android:layout_height="28dp"
            android:layout_marginLeft="8dp"
            android:background="@drawable/todo_widget_button_background"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/todo_widget_refresh"
            android:textAlignment="center"
            android:textColor="@color/todo_widget_accent"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ListView
        android:id="@+id/todo_widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:fadingEdge="none"
        android:listSelector="@android:color/transparent"
        android:scrollbarStyle="outsideOverlay" />

    <LinearLayout
        android:id="@+id/todo_widget_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/todo_widget_empty_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="@color/todo_widget_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/todo_widget_empty_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/todo_widget_muted"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/todo_widget_footer"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/todo_widget_more"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical|center_horizontal"
            android:maxLines="1"
            android:textColor="@color/todo_widget_muted"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
