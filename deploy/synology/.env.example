APP_PORT=8080
APP_TIMEZONE=Asia/Shanghai

AUTO_MIGRATE=true
ICS_IMPORT_HORIZON_DAYS=180
MAX_UPLOAD_SIZE_BYTES=4194304

SESSION_COOKIE_NAME=todo_session
SESSION_TTL_HOURS=720
SESSION_SECURE_COOKIE=false
SSO_PROVIDER_NAME=soid
SSO_ISSUER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URL=https://todo.example.com/auth/sso/callback
SSO_SCOPES=openid profile email
SSO_AUTO_REGISTER=true
SSO_AUTO_APPROVE=true

POSTGRES_DB=todo
POSTGRES_USER=todo
POSTGRES_PASSWORD=change_me

# 使用内置 PostgreSQL 时，保持下面这行指向 db 服务。
DATABASE_URL=postgres://todo:change_me@db:5432/todo?sslmode=disable

# 没有金句库就留空。
QUOTES_DATABASE_URL=
